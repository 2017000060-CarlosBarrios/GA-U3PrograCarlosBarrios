Algoritmo Horoscopo
    Escribir "Ingresa tu mes de nacimiento (1-12):"
    Leer mes
    Escribir "Ingresa tu día de nacimiento (1-31):"
    Leer dia
    
    Si (mes = 3 Y dia >= 21) O (mes = 4 Y dia <= 19) Entonces
        signo <- "Aries"
        horoscopo <- "Hoy es un buen día para emprender nuevos retos."
    Sino Si (mes = 4 Y dia >= 20) O (mes = 5 Y dia <= 20) Entonces
        signo <- "Tauro"
        horoscopo <- "La paciencia será tu mejor aliada en el trabajo."
    Sino Si (mes = 5 Y dia >= 21) O (mes = 6 Y dia <= 20) Entonces
        signo <- "Géminis"
        horoscopo <- "Una conversación interesante renovará tus ideas."
    Sino Si (mes = 6 Y dia >= 21) O (mes = 7 Y dia <= 22) Entonces
        signo <- "Cáncer"
        horoscopo <- "Dedica tiempo de calidad a tu familia."
    Sino Si (mes = 7 Y dia >= 23) O (mes = 8 Y dia <= 22) Entonces
        signo <- "Leo"
        horoscopo <- "Tu confianza te abrirá nuevas puertas."
    Sino Si (mes = 8 Y dia >= 23) O (mes = 9 Y dia <= 22) Entonces
        signo <- "Virgo"
        horoscopo <- "La organización te evitará contratiempos."
    Sino Si (mes = 9 Y dia >= 23) O (mes = 10 Y dia <= 22) Entonces
        signo <- "Libra"
        horoscopo <- "Busca el equilibrio en tus decisiones."
    Sino Si (mes = 10 Y dia >= 23) O (mes = 11 Y dia <= 21) Entonces
        signo <- "Escorpio"
        horoscopo <- "Confía en tu intuición hoy."
    Sino Si (mes = 11 Y dia >= 22) O (mes = 12 Y dia <= 21) Entonces
        signo <- "Sagitario"
        horoscopo <- "Un toque de aventura alegrará tu semana."
    Sino Si (mes = 12 Y dia >= 22) O (mes = 1 Y dia <= 19) Entonces
        signo <- "Capricornio"
        horoscopo <- "Tu disciplina traerá grandes resultados."
    Sino Si (mes = 1 Y dia >= 20) O (mes = 2 Y dia <= 18) Entonces
        signo <- "Acuario"
        horoscopo <- "Aprovecha tu creatividad al máximo."
    Sino Si (mes = 2 Y dia >= 19) O (mes = 3 Y dia <= 20) Entonces
        signo <- "Piscis"
        horoscopo <- "Escucha tu voz interior y descansa."
    Sino
        signo <- "Desconocido"
        horoscopo <- "Fecha no válida."
    FinSi
    
    Escribir "Tu signo es: ", signo
    Escribir "Horóscopo: ", horoscopo
FinAlgoritmo
