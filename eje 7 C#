using System;

class Program
{
    static void Main()
    {
        Console.Write("Ingrese grados Celsius (°C): ");
        double c = double.Parse(Console.ReadLine());

        double f = (c * 9 / 5) + 32;
        double k = c + 273.15;

        Console.WriteLine($"\na. Fahrenheit: {f}°F");
        Console.WriteLine($"b. Celsius: {c}°C");
        Console.WriteLine($"c. Kelvin: {k} K");
    }
}
