Algoritmo CalcularIMC
    Escribir "Ingrese peso en kilogramos (kg):"
    Leer peso
    Escribir "Ingrese altura en metros (m):"
    Leer altura
    
    imc <- peso / (altura * altura)
    Escribir "Su IMC es: ", imc
    
    Si imc < 18.5 Entonces
        Escribir "Categoría: Bajo peso"
    Sino Si imc < 25 Entonces
        Escribir "Categoría: Peso normal"
    Sino Si imc < 30 Entonces
        Escribir "Categoría: Sobrepeso"
    Sino
        Escribir "Categoría: Obesidad"
    FinSi
FinAlgoritmo
